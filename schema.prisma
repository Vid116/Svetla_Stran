generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StoryStatus {
  PENDING_TITLE_FILTER
  PENDING_SCORE
  PENDING_REVIEW
  APPROVED_CONCEPT
  PENDING_WRITE
  PENDING_EDITOR
  PUBLISHED
  REJECTED
  SKIPPED
}

enum SourceType {
  RSS
  SCRAPE
  READER_SUBMISSION
  MALI_SPORT
  MLADA_KMETIJA
}

enum StoryCategory {
  ZIVALI
  SKUPNOST
  SPORT
  NARAVA
  INFRASTRUKTURA
  PODJETNISTVO
  SLOVENIJA_V_SVETU
  JUNAKI
  KULTURA
}

model Story {
  id              String         @id @default(uuid())
  status          StoryStatus    @default(PENDING_TITLE_FILTER)
  sourceType      SourceType
  sourceUrl       String         // OBVEZNO - brez vira ni objave
  sourceName      String
  contentHash     String?        @unique
  rawTitle        String
  rawContent      String
  aiScore         Float?
  aiEmotions      String[]
  aiReason        String?
  aiCategory      StoryCategory?
  aiHeadline      String?
  ozadjeZgodbe    String?
  draftTitle      String?
  draftSubtitle   String?
  draftBody       String?
  draftSlug       String?        @unique
  category        StoryCategory?
  publishedAt     DateTime?
  postedInstagram Boolean        @default(false)
  postedFacebook  Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ReaderSubmission {
  id                 String    @id @default(uuid())
  name               String?
  email              String?
  storyText          String
  sourceUrl          String?
  categorySuggestion String?
  gdprConsent        Boolean
  status             String    @default("new")
  storyId            String?
  createdAt          DateTime  @default(now())
  notifiedAt         DateTime?
}

model FarmSubmission {
  id         String   @id @default(uuid())
  farmName   String
  kraj       String
  generacija String
  opis       String
  kontakt    String
  status     String   @default("new")
  storyId    String?
  createdAt  DateTime @default(now())
}

model ScrapingSource {
  id                   String         @id @default(uuid())
  name                 String
  type                 String
  url                  String
  categoryHint         StoryCategory?
  trustLevel           Int            @default(3)
  checkIntervalMinutes Int            @default(60)
  active               Boolean        @default(true)
  lastCheckedAt        DateTime?
  lastError            String?
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
